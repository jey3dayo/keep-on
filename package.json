{
  "name": "keep-on",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.16.0",
  "engines": {
    "node": "24.13.0",
    "pnpm": "11.16.0"
  },
  "scripts": {
    "dev": "dotenvx run --overload -f .env -f .env.development -- next dev --turbopack",
    "build": "if [ -n \"$CF_BUILD\" ]; then dotenvx run --overload -- next build; else dotenvx run --overload -f .env -f .env.development -- next build; fi",
    "build:cf": "CF_BUILD=1 dotenvx run --overload -- opennextjs-cloudflare build && node scripts/patch-open-next.mjs",
    "start": "dotenvx run --overload -f .env -f .env.development -- next start",
    "deploy": "run-s build:cf cf:deploy",
    "lint": "ultracite check",
    "format": "ultracite fix",
    "doctor": "ultracite doctor",
    "doctor:react": "react-doctor .",
    "test": "dotenvx run --overload -f .env -f .env.development -- vitest",
    "test:ui": "dotenvx run --overload -f .env -f .env.development -- vitest --ui",
    "test:run": "dotenvx run --overload -f .env -f .env.development -- vitest run",
    "test:coverage": "dotenvx run --overload -f .env -f .env.development -- vitest run --coverage",
    "test:storybook": "dotenvx run --overload -f .env -f .env.development -- vitest --config vitest.storybook.config.ts",
    "test:storybook:browser": "node scripts/storybook-smoke.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:setup": "playwright test --project=setup",
    "test:e2e:types": "tsc --project tsconfig.e2e.json --noEmit",
    "agent:setup": "./scripts/setup-auth-state.sh",
    "agent:browser": "tsx scripts/agent-browser-playwright.ts",
    "cf:deploy": "dotenvx run --overload -- wrangler deploy",
    "cf:preview": "dotenvx run -- opennextjs-cloudflare preview",
    "cf:logs": "dotenvx run -- wrangler tail --format pretty",
    "cf:secret": "dotenvx run -- wrangler secret",
    "cf:metrics": "./scripts/get-workers-metrics.sh",
    "cf:alerts": "./scripts/setup-cloudflare-alerts.sh",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "dotenvx run -- wrangler d1 execute keep-on-db --local --file",
    "db:migrate:remote": "dotenvx run -- wrangler d1 execute keep-on-db --remote --file",
    "db:studio": "dotenvx run --overload -f .env -f .env.development -- drizzle-kit studio --dialect=sqlite",
    "db:docs:generate": "tsx scripts/generate-dbml.ts",
    "db:docs:push": "dbdocs build docs/database/schema.dbml --project keep-on",
    "env:encrypt": "dotenvx encrypt && dotenvx encrypt -f .env.development",
    "env:decrypt": "dotenvx decrypt && dotenvx decrypt -f .env.development",
    "env:run": "dotenvx run --overload -f .env -f .env.development --",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.5.22",
    "@hookform/resolvers": "^5.4.0",
    "@opennextjs/cloudflare": "^1.20.2",
    "@paralleldrive/cuid2": "^3.3.0",
    "@praha/byethrow": "^0.12.0",
    "@praha/error-factory": "^1.4.1",
    "@radix-ui/colors": "^3.0.0",
    "@radix-ui/react-alert-dialog": "^1.1.21",
    "@radix-ui/react-avatar": "^1.2.4",
    "@radix-ui/react-dialog": "^1.1.21",
    "@radix-ui/react-dropdown-menu": "^2.1.22",
    "@radix-ui/react-label": "^2.1.13",
    "@radix-ui/react-progress": "^1.1.14",
    "@radix-ui/react-radio-group": "^1.4.5",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.19",
    "@radix-ui/react-tooltip": "^1.2.14",
    "@sentry/cloudflare": "^10.67.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "drizzle-orm": "0.45.2",
    "http-status-codes": "^2.3.0",
    "i18next": "^26.3.6",
    "lucide-react": "^1.26.0",
    "next": "^16.2.11",
    "next-themes": "^0.4.6",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "react-error-boundary": "^6.1.2",
    "react-hook-form": "^7.82.0",
    "react-i18next": "^17.0.11",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "valibot": "^1.4.2",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.5",
    "@cloudflare/workers-types": "^5.20260723.1",
    "@dotenvx/dotenvx": "^2.17.2",
    "@playwright/test": "^1.61.1",
    "@sentry/cli": "^3.6.2",
    "@storybook/addon-a11y": "^10.5.3",
    "@storybook/addon-docs": "^10.5.3",
    "@storybook/addon-themes": "^10.5.3",
    "@storybook/nextjs-vite": "^10.5.3",
    "@tailwindcss/postcss": "^4.3.3",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript/typescript6": "^6.0.2",
    "@vitejs/plugin-react": "^6.0.4",
    "@vitest/browser-playwright": "4.1.10",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/ui": "^4.1.10",
    "agentation": "^3.0.2",
    "dbdocs": "^1.3.1",
    "drizzle-dbml-generator": "^0.10.0",
    "drizzle-kit": "^0.31.10",
    "jsdom": "^29.1.1",
    "markdownlint-cli2": "^0.23.1",
    "npm-run-all2": "^9.0.2",
    "playwright": "^1.61.1",
    "sharp": "^0.35.3",
    "storybook": "^10.5.3",
    "tailwindcss": "^4.3.3",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "ultracite": "7.9.4",
    "vitest": "^4.1.10",
    "wrangler": "^4.113.0"
  }
}
