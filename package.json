{
  "name": "keep-on",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": "24.13.0",
    "pnpm": "10.30.3"
  },
  "scripts": {
    "dev": "dotenvx run --overload -f .env -f .env.development -- next dev --turbopack",
    "build": "dotenvx run --overload -f .env -f .env.development -- next build",
    "build:cf": "dotenvx run --overload -- opennextjs-cloudflare build && node scripts/patch-open-next.mjs",
    "start": "dotenvx run --overload -f .env -f .env.development -- next start",
    "deploy": "run-s build:cf cf:deploy",
    "lint": "ultracite check",
    "format": "ultracite fix",
    "doctor": "ultracite doctor",
    "doctor:react": "react-doctor .",
    "test": "dotenvx run --overload -f .env -f .env.development -- vitest",
    "test:ui": "dotenvx run --overload -f .env -f .env.development -- vitest --ui",
    "test:run": "dotenvx run --overload -f .env -f .env.development -- vitest run",
    "test:coverage": "dotenvx run --overload -f .env -f .env.development -- vitest run --coverage",
    "test:storybook": "dotenvx run --overload -f .env -f .env.development -- vitest --config vitest.storybook.config.ts",
    "test:storybook:browser": "node scripts/storybook-smoke.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:setup": "playwright test --project=setup",
    "test:e2e:types": "tsc --project tsconfig.e2e.json --noEmit",
    "agent:setup": "./scripts/setup-auth-state.sh",
    "agent:browser": "tsx scripts/agent-browser-playwright.ts",
    "cf:deploy": "dotenvx run -- wrangler deploy",
    "cf:preview": "dotenvx run -- opennextjs-cloudflare preview",
    "cf:logs": "dotenvx run -- wrangler tail --format pretty",
    "cf:secret": "dotenvx run -- wrangler secret",
    "cf:metrics": "./scripts/get-workers-metrics.sh",
    "cf:alerts": "./scripts/setup-cloudflare-alerts.sh",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "dotenvx run -- wrangler d1 execute keep-on-db --local --file",
    "db:migrate:remote": "dotenvx run -- wrangler d1 execute keep-on-db --remote --file",
    "db:studio": "dotenvx run --overload -f .env -f .env.development -- drizzle-kit studio --dialect=sqlite",
    "db:docs:generate": "tsx scripts/generate-dbml.ts",
    "db:docs:push": "dbdocs build docs/database/schema.dbml --project keep-on",
    "env:encrypt": "dotenvx encrypt && dotenvx encrypt -f .env.development",
    "env:decrypt": "dotenvx decrypt && dotenvx decrypt -f .env.development",
    "env:run": "dotenvx run --overload -f .env -f .env.development --",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.0.1",
    "@hookform/resolvers": "^5.2.2",
    "@opennextjs/cloudflare": "^1.17.1",
    "@paralleldrive/cuid2": "^3.3.0",
    "@praha/byethrow": "^0.10.0",
    "@praha/error-factory": "^1.4.0",
    "@radix-ui/colors": "^3.0.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sentry/cloudflare": "^10.42.0",
    "@sentry/core": "^10.42.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "0.45.1",
    "http-status-codes": "^2.3.0",
    "lucide-react": "^0.577.0",
    "next": "^16.1.6",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-error-boundary": "^6.1.1",
    "react-hook-form": "^7.71.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "valibot": "^1.2.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@cloudflare/workers-types": "^4.20260306.1",
    "@dotenvx/dotenvx": "^1.54.1",
    "@playwright/test": "^1.58.2",
    "@sentry/cli": "^3.3.0",
    "@storybook/addon-a11y": "^10.2.16",
    "@storybook/addon-docs": "^10.2.16",
    "@storybook/addon-themes": "^10.2.16",
    "@storybook/nextjs-vite": "^10.2.16",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.3.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/browser-playwright": "4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "agentation": "^2.2.1",
    "dbdocs": "^1.1.0",
    "drizzle-dbml-generator": "^0.10.0",
    "drizzle-kit": "^0.31.9",
    "happy-dom": "^20.8.3",
    "jsdom": "^28.1.0",
    "markdownlint-cli2": "^0.21.0",
    "npm-run-all2": "^8.0.4",
    "playwright": "^1.58.2",
    "sharp": "^0.34.5",
    "storybook": "^10.2.16",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "ultracite": "7.2.5",
    "vitest": "^4.0.18",
    "wrangler": "^4.71.0"
  }
}
